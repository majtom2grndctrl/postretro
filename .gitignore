# Generated by Cargo
# will have compiled files and executables
debug
target

# These are backup files generated by rustfmt
**/*.rs.bk

# MSVC Windows builds of rustc generate these, which store debugging information
*.pdb

# Generated by cargo mutants
# Contains mutation testing data
**/mutants.out*/

# Claude Code (local settings — project rules live in context/)
.claude/settings.local.json

# Compiled map assets (only *.map source files are tracked)
*.bsp
*.prl
# DISPOSABLE DOWNLOAD-BRANCH EXCEPTION (claude/stress-warren-overflow-download):
# this throwaway branch carries the pre-baked navigable overflow build so it can
# be downloaded without a local bake. Delete the branch to drop these from history.
!content/base/maps/stress-warren-overflow*.prl
# Autosave maps (local, not version controlled)
**/maps/autosave/
autosave/

# prl-build output trees, both dev-local and regenerable:
#   baked/         = runtime-REQUIRED compiled output (e.g. baked/materials/<hash>.prm
#                    texture mip sidecars). Regenerated by the next bake; no shipped
#                    data lives here.
#   .build-caches/ = DISPOSABLE stage cache (prl-cache/). Safe to delete at any time.
baked/*
# DISPOSABLE DOWNLOAD-BRANCH EXCEPTION: carry the .prm texture sidecars the
# navigable overflow build needs at runtime (content-addressed mips). Dropped
# when this throwaway branch is deleted.
!baked/materials/
baked/materials/*
!baked/materials/*.prm
.build-caches/

# Distribution artifacts
dist/

# Local agent tool binaries
tools/local-bin/

# RustRover
#  JetBrains specific template is maintained in a separate JetBrains.gitignore that can
#  be found at https://github.com/github/gitignore/blob/main/Global/JetBrains.gitignore
#  and can be added to the global gitignore or merged into this file.  For a more nuclear
#  option (not recommended) you can uncomment the following to ignore the entire idea folder.
#.idea/

.claude/worktrees/
.venv/

# macOS
.DS_Store

# Compiled script artifacts (source is .ts/.lua; outputs are generated)
*.js
*.lua
