# Generated by Cargo
# will have compiled files and executables
debug
target

# These are backup files generated by rustfmt
**/*.rs.bk

# MSVC Windows builds of rustc generate these, which store debugging information
*.pdb

# Generated by cargo mutants
# Contains mutation testing data
**/mutants.out*/

# Claude Code (local settings — project rules live in context/)
.claude/settings.local.json

# Compiled map assets (only *.map source files are tracked)
*.bsp
*.prl
# Exception: the committed stress-warren-overflow build, for direct download
# (verifies the multi-layer lightmap atlas without a local ~25-min bake).
!content/base/maps/stress-warren-overflow.prl
# Autosave maps (local, not version controlled)
**/maps/autosave/
autosave/

# prl-build cache directories. The stage cache (prl-cache) stays ignored; the
# .prm texture-mip sidecars are excepted so the overflow build downloads with
# real textures rather than placeholders.
.build-caches/*
!.build-caches/prm-cache/
.build-caches/prm-cache/*
!.build-caches/prm-cache/*.prm

# Distribution artifacts
dist/

# Local agent tool binaries
tools/local-bin/

# RustRover
#  JetBrains specific template is maintained in a separate JetBrains.gitignore that can
#  be found at https://github.com/github/gitignore/blob/main/Global/JetBrains.gitignore
#  and can be added to the global gitignore or merged into this file.  For a more nuclear
#  option (not recommended) you can uncomment the following to ignore the entire idea folder.
#.idea/

.claude/worktrees/
.venv/

# macOS
.DS_Store

# Compiled script artifacts (source is .ts/.lua; outputs are generated)
*.js
*.lua
